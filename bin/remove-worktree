#!/usr/bin/env bash

set -u -o pipefail

git worktree prune

if [[ $# -eq "0" || $# -gt "2" ]]; then
    echo "Usage: remove-worktree [-f] branch-name"
    exit
fi

branch_name=$1
STRIP="oalders/"

shift
echo "looking for branch: $branch_name"

# If we can't kill the tmux session, then that's ok. It may just not exist.
if [[ -n $(pgrep tmux) ]]; then
    # tmux session name will contain the git branch name
    session=$(tmux list-session | grep "$branch_name" | awk -v FS=':' '{print $1}')
    if [[ ${session-} ]]; then
        echo "Trying to kill tmux session $session"
        tmux kill-session -t "$session"
    fi
fi

# We need to be inside the repository in order to remove the worktree.
git_dir=$(git rev-parse --git-common-dir) || ( echo "cannot find --git-common-dir. are we inside a git repository?" && exit 1)
cd "$git_dir/.." || ( echo "cannot chdir to $git_dir/.." && exit 1)

# `add-worktree gh-N` creates a dir named `gh-N` but `gh pr checkout` then
# switches it to the PR's branch, so dir name ≠ branch name. Resolve to the
# worktree path before removing.
worktree_path=$(git worktree list --porcelain | awk -v ref="refs/heads/$branch_name" '
    /^worktree / { wt=$2 }
    $0 == "branch " ref { print wt; exit }
')
if [[ -z $worktree_path ]]; then
    worktree_path="$branch_name"
fi

# Kill any agent process trees (nono/claude/serena) still running inside
# the worktree before we remove it. tmux kill-session above only SIGHUPs
# the pane shell; sandboxed claude trees often survive that.
killer="$(dirname "${BASH_SOURCE[0]}")/kill-worktree-procs"
if [ -x "$killer" ]; then
    "$killer" "$worktree_path" || true
else
    echo "remove-worktree: warning: kill-worktree-procs not found; skipping process cleanup" >&2
fi

# git refuses to remove a worktree containing an initialized submodule unless
# --force is given (issue #977). Escalate to --force when .gitmodules is
# present, matching bin/merge-pr. This is already an aggressive teardown tool —
# it kills process trees and force-deletes the branch below — so discarding a
# submodule checkout here is in keeping.
if [ -f "$worktree_path/.gitmodules" ]; then
    git worktree remove --force "$@" "$worktree_path"
else
    git worktree remove "$@" "$worktree_path"
fi
git branch -D "$@" "$branch_name"

#!/bin/bash

set -eu -o pipefail

# When launched from a git worktree, the worktree's git dir lives under the
# main repo's .git/worktrees/<name> — outside cwd, so --allow-cwd doesn't
# cover it. Resolve the common git dir and grant it. No-op for regular repos
# (where common-dir == <cwd>/.git, already covered).
extra_allow=()
if common_dir=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null); then
    extra_allow=(--allow "$common_dir")
fi

# Prefer a project-local profile at .nono/profile.json over the global
# oalders profile. Walk up from cwd to the git toplevel (or stay at cwd if
# not in a repo) so the profile is picked up from any subdirectory.
profile=""
profile_label=""
stop_at=$(git rev-parse --show-toplevel 2>/dev/null || echo "$PWD")
dir="$PWD"
while :; do
    if [[ -f "$dir/.nono/profile.json" ]]; then
        profile="$dir/.nono/profile.json"
        profile_label="$profile"
        break
    fi
    [[ "$dir" == "$stop_at" || "$dir" == "/" ]] && break
    dir=$(dirname "$dir")
done

# No project-local profile found. Detect language stacks at the repo top
# and, if any match, drop a wrapper at <toplevel>/.nono/profile.json that
# composes oalders with the matching oalders-<stack> sibling(s). The next
# nn run picks it up via the same walk-up. Add new stacks by appending a
# detection block + mixin name. Delete .nono/profile.json to force a
# re-detect (e.g. after adding a new cpanfile to a previously bare repo).
# Tool-level always-on siblings (oalders-uv, oalders-serena, oalders-playwright,
# oalders-chrome) are pulled in via oalders.json's own extends list, so they
# don't need to live here.
if [[ -z "$profile" ]]; then
    mixins=()
    if [[ -f "$stop_at/cpanfile" || -f "$stop_at/Makefile.PL" || -f "$stop_at/dist.ini" ]]; then
        mixins+=("oalders-perl")
    fi
    if [[ -f "$stop_at/package.json" ]]; then
        mixins+=("oalders-node")
    fi
    if [[ -f "$stop_at/go.mod" ]]; then
        mixins+=("oalders-go")
    fi
    if (( ${#mixins[@]} > 0 )); then
        mkdir -p "$stop_at/.nono"
        extends='"oalders"'
        for m in "${mixins[@]}"; do
            extends="$extends, \"$m\""
        done
        printf '{"extends": [%s]}\n' "$extends" > "$stop_at/.nono/profile.json"
        profile="$stop_at/.nono/profile.json"
        profile_label="$profile (auto: oalders + ${mixins[*]})"
    else
        profile="oalders"
        profile_label="oalders"
    fi
fi

# Worktree-local scratch dir for $TMPDIR. Tools that honor TMPDIR (mktemp,
# Python tempfile, Perl File::Temp, gh, gnupg, etc.) will write here instead
# of /tmp, which keeps transient state inside --allow-cwd and out of the
# shared /tmp namespace.
mkdir -p .tmp/cache

# Worktree-local serena home. Two problems we're working around:
#   1. Without SERENA_HOME, serena reads ~/.serena's host-wide
#      registered_projects on startup and crashes on any path outside the
#      sandbox (Permission denied on project.yml).
#   2. Serena's default config sets web_dashboard: true, which tries to bind
#      a port from 24282 upward — Landlock blocks listen(), so serena exits
#      with "No free ports found". The dashboard's also pointless headless.
# Always overwrite with the seed: keeps the per-worktree registry empty and
# the dashboard disabled, single source of truth in nono/serena_config.yml.
mkdir -p .serena-home
seed="$HOME/.config/nono/serena_config.yml"
if [[ ! -e $seed ]]; then
    # installer/symlinks.sh creates this, but self-heal here so a fresh
    # `git pull` doesn't require re-running the installer before the next
    # nn launch. bin/nn runs outside the sandbox, so writing under
    # ~/.config/nono is allowed.
    mkdir -p "$(dirname "$seed")"
    ln -sf "$HOME/dot-files/nono/serena_config.yml" "$seed"
fi
cp "$seed" .serena-home/serena_config.yml

echo "🗯️nn: using profile $profile_label" >&2

set -x
# nono's allow_domain entries are injected into NO_PROXY inside the sandbox,
# which makes HTTP clients bypass the nono proxy — and Landlock then blocks
# the direct connection. Reset NO_PROXY to just loopback so HTTPS traffic
# goes through the proxy, where allow_domain actually takes effect. Set
# via `env` so it lands after nono's injection (calling-shell assignment
# would be overwritten by nono before claude launches).
exec nono run --profile "$profile" --allow-cwd --workdir . "${extra_allow[@]}" -- \
    env NO_PROXY=localhost,127.0.0.1 no_proxy=localhost,127.0.0.1 TMPDIR="$PWD/.tmp" \
    XDG_CACHE_HOME="$PWD/.tmp/cache" \
    SERENA_HOME="$PWD/.serena-home" \
    claude --settings "$HOME/.config/nono/claude-settings.json" \
    --dangerously-skip-permissions "$@"

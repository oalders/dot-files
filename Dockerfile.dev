# Universal dev container for running Claude Code in isolation.
# Build:  dev build
# Run:    dev claude
# Shell:  dev shell

FROM ubuntu:24.04@sha256:186072bba1b2f436cbb91ef2567abca677337cfc786c86e107d25b7072feef0c

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    iptables \
    ipset \
    iproute2 \
    jq \
    less \
    locales \
    man-db \
    openssh-client \
    perl \
    python3 \
    ripgrep \
    sqlite3 \
    sudo \
    vim \
    wget && \
    sed -i '/en_US.UTF-8/s/^# //' /etc/locale.gen && \
    locale-gen && \
    printf 'LANG=en_US.UTF-8\nLC_ALL=en_US.UTF-8\n' > /etc/default/locale
# Note: apt lists intentionally kept so dotfiles installer can use them

# Node.js 24.x (needed for Claude plugins, TypeScript LSP, npm packages)
RUN curl -sL https://deb.nodesource.com/setup_24.x | bash - && \
    apt-get install -y nodejs

# Go (needed for gopls, goimports, staticcheck, golangci-lint)
RUN ARCH="$(dpkg --print-architecture)" && \
    curl -sL "https://go.dev/dl/go1.24.1.linux-${ARCH}.tar.gz" | tar -C /usr/local -xz
ENV PATH="/usr/local/go/bin:${PATH}"

# Non-root user matching host UID/GID.
# Claude Code refuses --dangerously-skip-permissions when running as root.
# AGENT_UID/GID are passed at build time from the host user's id.
ARG AGENT_UID=1000
ARG AGENT_GID=1000
RUN userdel -r ubuntu 2>/dev/null || true && \
    groupadd -f -g "${AGENT_GID}" agent && \
    useradd -m -u "${AGENT_UID}" -g "${AGENT_GID}" -s /bin/bash agent && \
    echo "agent ALL=(ALL) NOPASSWD:SETENV:ALL" >> /etc/sudoers

# Playwright + Chromium
# Install browsers as root, then move to shared location and chown to agent.
# Done after user creation so chown stays in this layer (not re-run on dotfiles change).
RUN npm install -g @playwright/test@1.59.0 && \
    npx playwright install --with-deps chromium && \
    mv /root/.cache/ms-playwright /opt/ms-playwright && \
    chown -R agent:agent /opt/ms-playwright && \
    mkdir -p /opt/google/chrome && \
    ln -s /opt/ms-playwright/chromium-*/chrome-linux64/chrome /opt/google/chrome/chrome && \
    ln -s /opt/ms-playwright/chromium-*/chrome-linux64/chrome /usr/local/bin/chromium && \
    ln -s /opt/ms-playwright/chromium-*/chrome-linux64/chrome /usr/local/bin/chrome && \
    ln -s /opt/ms-playwright/chromium-*/chrome-linux64/chrome /usr/local/bin/google-chrome && \
    ln -s /opt/ms-playwright/chromium-*/chrome-linux64/chrome /usr/bin/google-chrome && \
    ln -s /opt/ms-playwright/chromium-*/chrome-linux64/chrome /usr/bin/chromium-browser && \
    ln -s /opt/ms-playwright/chromium-*/chrome-linux64/chrome /usr/bin/chromium
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/ms-playwright
# Chrome sandbox requires SYS_ADMIN capability which containers don't have.
ENV PLAYWRIGHT_MCP_SANDBOX=false

# Ensure ~/.local/bin is always in PATH for login shells.
# docker exec doesn't start a login shell so these aren't sourced from dotfiles.
RUN echo 'export PATH="${HOME}/.local/bin:${HOME}/local/bin:${PATH}"' \
    > /etc/profile.d/local-bin.sh

# Copy dotfiles from host (passed as --build-context dotfiles=~/dot-files at build time).
# Avoids a GitHub clone and always uses your local working copy.
# GITHUB_TOKEN injected via BuildKit secret (never stored in image history).
COPY --from=dotfiles . /home/agent/dot-files
RUN --mount=type=secret,id=github_token \
    chown -R agent:agent /home/agent/dot-files && \
    rm -f /home/agent/.bashrc /home/agent/.bash_profile /home/agent/.profile && \
    cd /home/agent/dot-files && \
    export GH_TOKEN="$(cat /run/secrets/github_token 2>/dev/null)" && \
    sudo -u agent \
        GH_TOKEN="$GH_TOKEN" \
        GITHUB_TOKEN="$GH_TOKEN" \
        DEBIAN_FRONTEND=noninteractive \
        HOME=/home/agent \
        bash dev-vm-install.sh

# dnsutils needed by claude-firewall.sh (dig), gnupg kept for future repo additions
RUN apt-get install -y --no-install-recommends gnupg dnsutils

USER agent

# Firewall script for restricting container network access
COPY --chmod=755 --from=dotfiles bin/claude-firewall.sh /usr/local/bin/claude-firewall.sh

# Go dev tools:
#   gopls      - Go language server (Serena)
#   goimports  - import sorting (precious tidy)
#   staticcheck - Go static analysis
#   golangci-lint - Go linting (precious lint)
# CGO_ENABLED=0 for golangci-lint since gcc is not in the image.
RUN GOTOOLCHAIN=auto GOPATH=/home/agent/go /usr/local/go/bin/go install golang.org/x/tools/gopls@v0.21.1 && \
    GOTOOLCHAIN=auto GOPATH=/home/agent/go /usr/local/go/bin/go install golang.org/x/tools/cmd/goimports@v0.43.0 && \
    GOTOOLCHAIN=auto GOPATH=/home/agent/go /usr/local/go/bin/go install honnef.co/go/tools/cmd/staticcheck@v0.7.0 && \
    GOTOOLCHAIN=auto CGO_ENABLED=0 GOPATH=/home/agent/go /usr/local/go/bin/go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.11.4 && \
    npm install --prefix /home/agent/.local -g cc-pulse@1.6.1

# Pre-warm the uvx cache for Serena so the MCP server starts within Claude's
# connection timeout. First run clones and installs from git — too slow live.
RUN /home/agent/.local/bin/uvx --from git+https://github.com/oraios/serena@v0.1.4 serena --help || true

# Claude Code marketplaces and plugins (baked into image, not mounted from host).
# GH_TOKEN avoids GitHub API rate limits during plugin installation.
RUN --mount=type=secret,id=github_token \
    export GH_TOKEN="$(cat /run/secrets/github_token 2>/dev/null)" && \
    export HOME=/home/agent && \
    export PATH="/home/agent/local/bin:/home/agent/.local/bin:${PATH}" && \
    /home/agent/dot-files/configure/claude.sh

# Locale and PATH for user-installed tools.
# docker exec doesn't start a login shell so these aren't sourced from dotfiles.
ENV LANG=en_US.UTF-8
ENV LC_ALL=en_US.UTF-8
ENV PATH="/home/agent/go/bin:/home/agent/local/bin:/home/agent/.local/bin:${PATH}"
WORKDIR /workspace

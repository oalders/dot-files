{
  "meta": {
    "name": "oalders-go-cgo-dev",
    "description": "Go SDK + cgo development on top of oalders (Go toolchain, system C headers, pkg-config)"
  },
  "extends": "oalders",
  "security": {
    "groups": ["go_runtime"]
  },
  "policy": {
    "add_allow_read": [
      "/usr/include",
      "/usr/local/include",
      "/Library/Developer/CommandLineTools",
      "/opt/homebrew/include",
      "/opt/homebrew/lib/pkgconfig",
      "/opt/homebrew/share/pkgconfig"
    ]
  }
}

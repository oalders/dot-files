{
  "meta": {
    "name": "oalders-hugo",
    "description": "Hugo static site generator: cache directory"
  },
  "filesystem": {
    "allow": [
      "~/.cache/hugo_cache"
    ],
    "read": [
      "/etc/magic",
      "~/Downloads"
    ]
  },
  "network": {
    "allow_domain": [
      "api.openverse.org",
      "code.claude.com",
      "commons.wikimedia.org",
      "flickr.com",
      "fosstodon.org",
      "*.fosstodon.org",
      "media.licdn.com",
      "metacpan.org",
      "*.metacpan.org",
      "neilb.org",
      "openverse.org",
      "registry.npmjs.org",
      "*.staticflickr.com",
      "upload.wikimedia.org",
      "web.archive.org",
      "www.flickr.com",
      "www.olafalders.com"
    ]
  }
}

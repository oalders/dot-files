{
  "meta": {
    "name": "oalders-hugo",
    "description": "Hugo static site generator: cache directory"
  },
  "filesystem": {
    "allow": [
      "~/.cache/hugo_cache"
    ],
    "read": [
      "/etc/magic",
      "~/Downloads"
    ]
  },
  "network": {
    "allow_domain": [
      "api.openverse.org",
      "openverse.org",
      "*.staticflickr.com",
      "www.flickr.com"
    ]
  }
}

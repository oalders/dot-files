{
  "extends": "claude-code",
  "security": {
    "signal_mode": "allow_same_sandbox",
    "process_info_mode": "allow_same_sandbox",
    "ipc_mode": "full"
  },
  "filesystem": {
    "read": [
      "~/dot-files/nono",
      "~/dot-files/bin",
      "~/local/bin",
      "/usr/local/",
      "~/.config/gh",
      "~/.local/bin",
      "~/.local/share/nvim/mason",
      "~/.local/share/uv",
      "~/.npm-packages",
      "~/.cache/ms-playwright",
      "/opt/google/chrome",
      "/usr/libexec/gcc"
    ],
    "allow": [
      "/tmp/claude-1000",
      "~/.serena",
      "~/.cache/golangci-lint",
      "~/.cache/superpowers",
      "~/.cache/go-build",
      "~/go/pkg/mod",
      "/dev/shm"
    ],
    "read_file": [
      "/etc/gitconfig",
      "~/.docker/config.json"
    ]
  },
  "network": {
    "network_profile": null,
    "allow_domain": [
      "proxy.golang.org",
      "sum.golang.org",
      "api.anthropic.com",
      "*.anthropic.com",
      "claude.ai",
      "*.claude.ai",
      "github.com",
      "*.github.com",
      "*.githubusercontent.com",
      "registry.npmjs.org",
      "*.npmjs.org"
    ],
    "open_port": [80, 5000, 5001, 8080]
  }
}

{
  "extends": "claude-code",
  "security": {
    "signal_mode": "allow_same_sandbox",
    "process_info_mode": "allow_same_sandbox",
    "ipc_mode": "full"
  },
  "filesystem": {
    "read": [
      "~/dot-files/nono",
      "~/local/bin",
      "/usr/local/",
      "~/.config/gh",
      "~/.local/bin",
      "~/.local/share/uv",
      "~/.npm-packages",
      "~/.cache/ms-playwright",
      "/opt/google/chrome"
    ],
    "allow": [
      "/tmp/claude-1000",
      "~/.serena",
      "~/.cache/superpowers",
      "/dev/shm"
    ],
    "read_file": [
      "/etc/gitconfig"
    ]
  },
  "network": {
    "allow_domain": [
      "api.anthropic.com",
      "*.github.com",
      "github.com"
    ]
  }
}

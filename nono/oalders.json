{
  "extends": [
    "claude-code",
    "oalders-uv",
    "oalders-serena",
    "oalders-playwright",
    "oalders-chrome"
  ],
  "security": {
    "signal_mode": "allow_same_sandbox",
    "process_info_mode": "allow_same_sandbox",
    "ipc_mode": "full"
  },
  "filesystem": {
    "read": [
      "/usr/libexec/gcc",
      "/usr/local/",
      "~/.config/gh",
      "~/.gitconfig",
      "~/.local/bin",
      "~/.local/share/nvim/mason",
      "~/.npm-packages",
      "~/dot-files/bin",
      "~/dot-files/gitignore_global",
      "~/dot-files/node_modules",
      "~/dot-files/nono",
      "~/local/bin"
    ],
    "allow": [
      "/tmp/claude-1000"
    ],
    "read_file": [
      "/etc/bash.bashrc",
      "/etc/gitconfig",
      "~/.bashrc",
      "~/.docker/config.json",
      "~/dot-files/bashrc"
    ],
    "bypass_protection": [
      "~/.bashrc",
      "~/dot-files/bashrc"
    ]
  },
  "network": {
    "network_profile": null,
    "allow_domain": [
      "*.anthropic.com",
      "*.claude.ai",
      "*.github.com",
      "*.githubusercontent.com",
      "api.anthropic.com",
      "claude.ai",
      "github.com"
    ],
    "open_port": [80, 5000, 5001, 8080]
  }
}

{
  "extends": "claude-code",
  "security": {
    "signal_mode": "allow_same_sandbox",
    "process_info_mode": "allow_same_sandbox",
    "ipc_mode": "full"
  },
  "filesystem": {
    "read": [
      "/opt/google/chrome",
      "/usr/libexec/gcc",
      "/usr/local/",
      "~/.cache/ms-playwright",
      "~/.config/gh",
      "~/.gitconfig",
      "~/.local/bin",
      "~/.local/share/nvim/mason",
      "~/.local/share/uv",
      "~/.npm-packages",
      "~/.plenv",
      "~/.proverc",
      "~/dot-files/bin",
      "~/dot-files/nono",
      "~/local/bin",
      "~/perl5"
    ],
    "allow": [
      "/dev/shm",
      "/tmp/claude-1000",
      "~/.cache/go-build",
      "~/.cache/golangci-lint",
      "~/.cache/superpowers",
      "~/.serena",
      "~/go/pkg/mod"
    ],
    "read_file": [
      "/etc/gitconfig",
      "~/.docker/config.json"
    ]
  },
  "network": {
    "network_profile": null,
    "allow_domain": [
      "*.anthropic.com",
      "*.claude.ai",
      "*.github.com",
      "*.githubusercontent.com",
      "*.npmjs.org",
      "api.anthropic.com",
      "claude.ai",
      "github.com",
      "proxy.golang.org",
      "registry.npmjs.org",
      "sum.golang.org"
    ],
    "open_port": [80, 5000, 5001, 8080]
  }
}
